{
  "expo": {
    "name": "Evaspoika",
    "slug": "Evaspoika",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "evaspoika",
    "userInterfaceStyle": "automatic",
    "extra": {
      "apiBaseUrl": "http://10.214.33.15:3000/api",
      "router": {},
      "eas": {
        "projectId": "a9bdf897-5950-4af7-aa8f-002a38f28a68"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.evaspoika.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.evaspoika.app",
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
